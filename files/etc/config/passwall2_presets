
config global 'global'
	option preset 'best_node'
	option strategy 'stable'

config observer 'main'
	option enabled '1'
	option interval '30'
	option socks_port ''
	option watchdog_enabled '1'
	option grace_period '30'
	option xray_dead_action 'restart'

# Probe A — IP via proxy (leak monitor; also the watchdog's death signal). Defaults are
# fine to ship because these are region-neutral utility endpoints, not project targets.
config probe 'ip_via_proxy'
	option enabled '1'
	list ip_check_url 'https://ifconfig.me/ip'
	list ip_check_url 'https://2ip.io'
	list ip_check_url 'https://api.ipify.org'

# Probe B — blocked resource via proxy. NO default host: this project targets more than
# just Russia (also Iran, North Korea, etc.), each with a different block list — the user
# must fill this in for their own region. Disabled until they do.
config probe 'blocked_via_proxy'
	option enabled '0'
	list host ''

# Probe C — IP via direct/shunt path. Requires the user to have set up a direct rule that
# routes at least one of these IP-checker hosts outside the proxy — see README for the
# how-to. Disabled until Probe C's own setup is confirmed.
config probe 'ip_direct'
	option enabled '0'
	list ip_check_url 'https://ifconfig.me/ip'
	list ip_check_url 'https://2ip.io'

# Probe D — unblocked resource via direct path (baseline WAN sanity check). NO default
# host, same reasoning as Probe B.
config probe 'unblocked_direct'
	option enabled '0'
	list host ''

# Widget field visibility — controls which Overview rows also appear on the compact
# standalone widget page (admin/services/passwall2-presets/widget). The full Overview
# tab always shows every row regardless of these settings; this only trims the widget.
# Configured from Settings > Widget. Section named 'widget', not 'main', because UCI
# section names must be unique file-wide across all types, and 'main' is already used
# by 'config observer'.
config widget 'widget'
	option show_watchdog_status '1'
	option show_xray_process '1'
	option show_probe_a '1'
	option show_probe_c '1'
	option show_probe_b '1'
	option show_probe_d '1'
	option show_last_updated '1'
	option show_configured_nodes '1'
	option show_active_balancer '1'
